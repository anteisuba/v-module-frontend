generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 用于迁移的直接连接
}

enum PayoutProvider {
  STRIPE
}

enum SellerPayoutAccountStatus {
  NOT_STARTED
  PENDING
  RESTRICTED
  ACTIVE
  DISCONNECTED
}

enum PaymentRoutingMode {
  PLATFORM
  STRIPE_CONNECT_DESTINATION
}

model MediaAsset {
  id     String  @id @default(cuid())
  userId String? // 可选：普通用户 ID
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 图片 URL（本地路径或 S3/R2 URL）
  // 本地：/uploads/user-slug/filename.jpg
  // S3/R2：https://your-domain.com/uploads/user-slug/filename.jpg
  src          String
  mimeType     String
  size         Int
  originalName String?
  usageContexts String[] @default([])

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ============================================
// 新增：普通用户（VTuber）
// ============================================
model User {
  id           String   @id @default(cuid())
  slug         String   @unique // URL 友好标识，用于 /u/[slug]
  email        String   @unique // 登录邮箱
  passwordHash String // bcrypt 加密后的密码
  displayName  String? // 显示名称（可选）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 关系
  page                Page? // 1:1，每个用户一个页面
  passwordResetTokens UserPasswordResetToken[]
  mediaAssets         MediaAsset[] // 用户上传的媒体资源
  newsArticles        NewsArticle[] // 用户创建的新闻文章
  blogPosts           BlogPost[] // 用户创建的博客文章
  products            Product[] // 用户创建的商品
  orders              Order[] // 用户创建的订单（作为卖家）
  payoutAccounts      SellerPayoutAccount[] // 卖家收款账户
  orderDisputes       OrderDispute[] // 支付争议 / chargeback
  settlementEntries   PaymentSettlementEntry[] // 支付结算流水
  blogLikes           BlogLike[] // 用户点赞的博客
  blogComments        BlogComment[] // 用户发表的评论

  // 索引
  @@index([slug])
  @@index([email])
}

model SellerPayoutAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          PayoutProvider
  providerAccountId String   @unique // Stripe connected account id, e.g. acct_xxx
  status            SellerPayoutAccountStatus @default(NOT_STARTED)

  accountType         String   @default("STRIPE_EXPRESS")
  country             String?
  defaultCurrency     String?  @default("JPY")
  businessType        String?
  displayNameSnapshot String?

  detailsSubmitted Boolean @default(false)
  chargesEnabled   Boolean @default(false)
  payoutsEnabled   Boolean @default(false)

  requirementsCurrentlyDue Json?
  requirementsEventuallyDue Json?
  requirementsPastDue Json?
  disabledReason     String?

  bankNameMasked  String?
  bankLast4Masked String?

  onboardingStartedAt   DateTime?
  onboardingCompletedAt DateTime?
  lastSyncedAt          DateTime?
  disconnectedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([userId, provider])
  @@index([userId, provider, status])
  @@index([provider, providerAccountId])
}

// ============================================
// 新增：页面配置（分离草稿和发布版本）
// ============================================
model Page {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug String @unique // 页面 slug，用于 /u/[slug] 路由

  // 草稿配置（编辑时保存）
  draftConfig Json? // 完整的页面配置 JSON（可包含未完成的编辑）

  // 发布配置（发布时从 draftConfig 复制过来）
  publishedConfig Json? // 公开可见的配置（/u/[slug] 读取这个）

  // 主题配置
  themeColor String @default("#000000") // 品牌主题色
  fontFamily String @default("Inter") // 字体家族

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

// ============================================
// 用户密码重置 Token
// ============================================
model UserPasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique // 哈希后的 token（用于查找和验证）
  userId    String // User.id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// 新闻文章
// ============================================
model NewsArticle {
  id     String @id @default(cuid())
  userId String // 所属用户
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 基本信息
  title    String // 标题
  content  String  @db.Text // 内容（支持 Markdown）
  category String // 分类（如 "MEDIA", "MAGAZINE", "あの", "ANO"）
  tag      String? // 标签（如 "あの"）

  // 分享相关
  shareUrl      String? // 分享链接（可打开）
  shareChannels Json? // 分享渠道配置 [{platform: "twitter", enabled: true}, ...]

  // 背景相关
  backgroundType  String? @default("color") // "color" | "image"
  backgroundValue String? @default("#000000") // 颜色值或图片 URL

  // 元数据
  published   Boolean   @default(false) // 是否发布
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime? // 发布时间

  @@index([userId, createdAt])
  @@index([published, createdAt])
  @@index([category])
}

// ============================================
// 博客文章
// ============================================
model BlogPost {
  id     String @id @default(cuid())
  userId String // 所属用户
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 基本信息
  title         String // 标题
  content       String  @db.Text // 内容（支持 Markdown）
  coverImage    String? // 封面图片 URL
  videoUrl      String? // 视频 URL
  externalLinks Json? // 外部链接 [{url: "...", label: "..."}, ...]

  // 元数据
  published   Boolean   @default(false) // 是否发布
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime? // 发布时间

  // 关系
  likes    BlogLike[] // 点赞
  comments BlogComment[] // 评论

  @@index([userId, createdAt])
  @@index([published, createdAt])
}

// ============================================
// 商品
// ============================================
model Product {
  id     String @id @default(cuid())
  userId String // 所属用户（卖家）
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 基本信息
  name        String // 商品名称
  description String? @db.Text // 商品描述
  price       Decimal @db.Decimal(10, 2) // 价格（使用 Decimal 类型，精度 10，小数位 2）
  stock       Int     @default(0) // 库存数量
  images      Json // 图片 URL 数组 ["url1", "url2", ...]
  status      String  @default("DRAFT") // 状态：DRAFT, PUBLISHED, ARCHIVED

  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  orderItems OrderItem[] // 订单项

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([userId, status])
}

// ============================================
// 博客点赞
// ============================================
model BlogLike {
  id         String   @id @default(cuid())
  blogPostId String // 博客文章 ID
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  userId     String? // 用户 ID（可选，允许匿名点赞）
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userEmail  String? // 用户邮箱（用于匿名用户）
  createdAt  DateTime @default(now())

  @@index([blogPostId, createdAt])
  @@index([userId])
  @@index([blogPostId, userId])
  @@index([blogPostId, userEmail])
}

// ============================================
// 博客评论
// ============================================
model BlogComment {
  id         String   @id @default(cuid())
  blogPostId String // 博客文章 ID
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  userId     String? // 用户 ID（可选，允许匿名评论）
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName   String // 评论者名称（必填）
  userEmail  String? // 用户邮箱（可选）
  content    String   @db.Text // 评论内容
  status     String   @default("PENDING") // 审核状态：PENDING, APPROVED, REJECTED
  moderatedAt DateTime? // 最后一次审核时间
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([blogPostId, createdAt])
  @@index([blogPostId, status, createdAt])
  @@index([status, createdAt])
  @@index([userId])
}

// ============================================
// 订单
// ============================================
model Order {
  id     String @id @default(cuid())
  userId String // 卖家用户 ID
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payoutAccountId    String?
  payoutAccount      SellerPayoutAccount? @relation(fields: [payoutAccountId], references: [id], onDelete: SetNull)
  paymentRoutingMode PaymentRoutingMode   @default(PLATFORM)
  connectedAccountId String?
  externalChargeId   String?
  externalTransferId String?
  platformFeeAmount  Decimal? @db.Decimal(10, 2)
  sellerGrossAmount  Decimal? @db.Decimal(10, 2)
  sellerNetExpectedAmount Decimal? @db.Decimal(10, 2)

  // 买家信息
  buyerEmail String // 买家邮箱
  buyerName  String? // 买家姓名（可选）

  // 订单金额
  totalAmount Decimal @db.Decimal(10, 2) // 订单总金额
  currency    String  @default("JPY") // 货币，Stripe Checkout 第一阶段默认 JPY

  // 订单状态
  status String @default("PENDING") // 状态：PENDING, AWAITING_PAYMENT, PAID, SHIPPED, DELIVERED, CANCELLED

  // 支付相关
  paymentProvider      String? // 支付提供方，如 STRIPE
  paymentStatus        String? // OPEN, PAID, FAILED, EXPIRED, PARTIALLY_REFUNDED, REFUNDED
  paymentSessionId     String? @unique // Stripe Checkout Session ID
  paymentIntentId      String? @unique // Stripe PaymentIntent ID
  paymentExpiresAt     DateTime? // 支付会话过期时间
  paymentFailedAt      DateTime? // 支付失败 / 过期时间
  paymentFailureReason String? // 失败原因，便于排查

  // 配送信息
  shippingAddress Json? // 配送地址 JSON
  shippingMethod  String? // 配送方式

  // 时间戳
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime? // 支付时间
  shippedAt   DateTime? // 发货时间
  deliveredAt DateTime? // 送达时间

  // 关系
  items           OrderItem[] // 订单项
  paymentAttempts OrderPaymentAttempt[] // 支付尝试
  refunds         OrderRefund[] // 退款记录
  disputes        OrderDispute[] // 支付争议
  settlementEntries PaymentSettlementEntry[] // 结算流水

  @@index([userId, createdAt])
  @@index([buyerEmail, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([paymentProvider, createdAt])
  @@index([payoutAccountId, createdAt])
  @@index([paymentRoutingMode, createdAt])
  @@index([connectedAccountId])
  @@index([externalChargeId])
}

model OrderPaymentAttempt {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider                String
  status                  String // OPEN, PAID, FAILED, EXPIRED
  amount                  Decimal @db.Decimal(10, 2)
  currency                String  @default("JPY")
  connectedAccountId      String?
  externalChargeId        String?
  externalTransferId      String?
  applicationFeeAmount    Decimal? @db.Decimal(10, 2)
  externalSessionId       String?
  externalPaymentIntentId String?
  failureReason           String?
  metadata                Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paidAt    DateTime?
  failedAt  DateTime?
  expiredAt DateTime?

  @@index([orderId, createdAt])
  @@index([provider, status, createdAt])
  @@index([connectedAccountId])
  @@index([externalChargeId])
  @@index([externalSessionId])
  @@index([externalPaymentIntentId])
}

model OrderRefund {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider                String
  status                  String // PENDING, SUCCEEDED, FAILED, CANCELED
  amount                  Decimal @db.Decimal(10, 2)
  currency                String  @default("JPY")
  reason                  String?
  failureReason           String?
  connectedAccountId      String?
  externalChargeId        String?
  externalRefundId        String? @unique
  externalPaymentIntentId String?
  externalTransferReversalId String?
  applicationFeeRefundedAmount Decimal? @db.Decimal(10, 2)
  requestedByUserId       String?
  metadata                Json?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  refundedAt DateTime?

  settlementEntries PaymentSettlementEntry[] // 对应的结算流水

  @@index([orderId, createdAt])
  @@index([provider, status, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([connectedAccountId])
  @@index([externalChargeId])
  @@index([externalPaymentIntentId])
}

model OrderDispute {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  orderId String?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  provider                String
  status                  String
  reason                  String?
  amount                  Decimal @db.Decimal(10, 2)
  currency                String  @default("JPY")
  externalDisputeId       String  @unique
  externalPaymentIntentId String?
  externalChargeId        String?
  connectedAccountId      String?
  externalTransferReversalId String?
  dueBy                   DateTime?
  closedAt                DateTime?
  metadata                Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, updatedAt])
  @@index([orderId, updatedAt])
  @@index([provider, status, updatedAt])
  @@index([externalPaymentIntentId])
  @@index([externalChargeId])
  @@index([connectedAccountId])
}

model PaymentSettlementPayout {
  id String @id @default(cuid())

  provider         String
  stripeAccountId  String?
  accountScope     String?
  externalPayoutId String @unique
  status           String
  amount           Decimal @db.Decimal(10, 2)
  currency         String  @default("JPY")
  payoutMethod     String?
  description      String?
  statementDescriptor String?
  rawData          Json?

  payoutCreatedAt DateTime
  arrivalDate     DateTime?
  paidAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries PaymentSettlementEntry[]

  @@index([provider, payoutCreatedAt])
  @@index([status, arrivalDate])
  @@index([stripeAccountId, payoutCreatedAt])
}

model PaymentSettlementEntry {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  orderId String?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  refundId String?
  refund   OrderRefund? @relation(fields: [refundId], references: [id], onDelete: SetNull)

  payoutId String?
  payout   PaymentSettlementPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  provider                     String
  stripeAccountId              String?
  accountScope                 String?
  externalBalanceTransactionId String @unique
  externalSourceId             String?
  externalSourceType           String?
  type                         String
  reportingCategory            String?
  status                       String
  amount                       Decimal @db.Decimal(10, 2)
  fee                          Decimal @db.Decimal(10, 2)
  net                          Decimal @db.Decimal(10, 2)
  currency                     String  @default("JPY")
  description                  String?
  occurredAt                   DateTime
  availableOn                  DateTime?
  reconciliationStatus         String  @default("OPEN")
  reconciliationNote           String?
  reconciledAt                 DateTime?
  sourceMetadata               Json?
  rawData                      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, occurredAt])
  @@index([orderId, occurredAt])
  @@index([refundId, occurredAt])
  @@index([payoutId, availableOn])
  @@index([provider, status, occurredAt])
  @@index([reconciliationStatus, occurredAt])
  @@index([stripeAccountId, availableOn])
  @@index([externalSourceId])
}

// ============================================
// 订单项（订单与商品的关联表）
// ============================================
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String // 订单 ID
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String // 商品 ID
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  // 下单时的价格快照（商品价格可能变化，需要记录下单时的价格）
  price    Decimal @db.Decimal(10, 2) // 下单时的单价
  quantity Int // 购买数量
  subtotal Decimal @db.Decimal(10, 2) // 小计（price * quantity）

  createdAt DateTime @default(now())

  @@unique([orderId, productId]) // 一个订单中同一商品只能出现一次
  @@index([orderId])
  @@index([productId])
}
