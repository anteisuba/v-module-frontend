{
  "name": "vtuber-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "node scripts/run-node-tool.mjs next dev",
    "build": "node scripts/run-prisma-generate.mjs && node scripts/run-node-tool.mjs next build",
    "build:test": "node scripts/run-prisma-generate.mjs && node scripts/run-node-tool.mjs next build",
    "start": "next start",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-node-tool.mjs playwright test",
    "postinstall": "node scripts/run-prisma-generate.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "db:migrate:status": "tsx scripts/apply-migrations.ts --status",
    "db:migrate:prisma-dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clear-rate-limit": "tsx scripts/clear-rate-limit.ts",
    "playwright:install": "playwright install chromium firefox webkit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.957.0",
    "@prisma/client": "6.19.1",
    "bcryptjs": "^3.0.3",
    "iron-session": "^8.0.4",
    "next": "16.0.10",
    "next-intl": "^4.7.0",
    "nodemailer": "^6.9.8",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-player": "^3.4.0",
    "resend": "^6.6.0",
    "stripe": "^20.4.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "daisyui": "^5.5.14",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prisma": "^6.19.1",
    "react-dev-inspector": "^2.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
